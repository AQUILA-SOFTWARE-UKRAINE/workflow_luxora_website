# Telegram bot token — obtain from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram chat ID that receives new leads.
# For a group: forward any message from the group to @userinfobot to get the ID.
MANAGER_CHAT_ID=

# Supabase project credentials — Settings → API in the Supabase dashboard.
# Use the SERVICE ROLE key (not the anon key). Never expose this in the browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret between this bot and the Supabase Database Webhook.
# Set this value as the Authorization header in the Supabase webhook config.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# Port the bot's HTTP server listens on (Supabase webhook endpoint + /health)
PORT=8080
